<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="MiHobbyC" />
		<Option pch_mode="2" />
		<Option compiler="gcc-msys2-mingw64" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/MiHobbyC" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc-msys2-mingw64" />
			</Target>
			<Target title="Release">
				<Option output="bin/Release/MiHobbyC" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc-msys2-mingw64" />
			</Target>
		</Build>
		<Compiler>
			<Add option="-fexpensive-optimizations" />
			<Add option="-std=c23" />
			<Add option="-m64" />
		</Compiler>
		<Linker>
			<Add option="-O3" />
			<Add option="-static-libgcc" />
			<Add option="-m64" />
		</Linker>
		<Unit filename="MiHobbyC.cbp" />
		<Unit filename="MiHobbyC.depend" />
		<Unit filename="database.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="database.h" />
		<Unit filename="hobby.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="hobby.h" />
		<Unit filename="main.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="recurso.rc">
			<Option compilerVar="WINDRES" />
		</Unit>
		<Unit filename="sqlite3.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="sqlite3.h" />
		<Extensions>
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
